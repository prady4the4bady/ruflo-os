# Ruflo OS Custom Kernel Configuration
CONFIG_LOCALVERSION="-ruflo"
CONFIG_DEFAULT_HOSTNAME="ruflo-os"

# AI Bridge Module
CONFIG_AI_BRIDGE=m
CONFIG_RUFLO_INPUT=m

# eBPF Support
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_KPROBE_OVERRIDE=y

# Input Subsystem
CONFIG_INPUT=y
CONFIG_INPUT_UINPUT=m
CONFIG_INPUT_EVDEV=y

# Netlink Support
CONFIG_NET=y
CONFIG_NETLINK_DIAG=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_SECURITY_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Filesystem
CONFIG_EXT4_FS=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y

# Namespace Support
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# Docker Support
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y

# Wayland / Graphics
CONFIG_DRM=y
CONFIG_DRM_WAYLAND=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y