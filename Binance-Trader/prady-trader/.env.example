# ============================================
# PRADY TRADER — Environment Variables
# ALL services are FREE. See comments below.
# ============================================

# BINANCE SPOT
# BINANCE_API_KEY / BINANCE_SECRET_KEY remain the legacy live-spot fallback pair.
# BINANCE_TESTNET_API_KEY / BINANCE_TESTNET_SECRET_KEY are the only keys used for spot testnet.
# BINANCE_LIVE_API_KEY / BINANCE_LIVE_SECRET_KEY are optional explicit live-spot overrides.
# BINANCE_TLD controls the live spot host. Use us for Binance US.
# Market data endpoints work WITHOUT any key at all.
BINANCE_API_KEY=your_live_spot_api_key
BINANCE_SECRET_KEY=your_live_spot_secret
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_SECRET_KEY=
BINANCE_TLD=com
BINANCE_TESTNET_API_KEY=your_spot_testnet_api_key
BINANCE_TESTNET_SECRET_KEY=your_spot_testnet_secret
BINANCE_TESTNET=true

# TRADING MODE (ALWAYS start with paper)
TRADING_MODE=paper

# RISK PARAMETERS
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_CONCURRENT_POSITIONS=3
MAX_CONSECUTIVE_LOSSES=3
KELLY_FRACTION=0.25
MIN_CONFIDENCE=0.85
DEFAULT_LEVERAGE=5
LIVE_MIN_REHEARSAL_TRADES=20
LIVE_MIN_REHEARSAL_WIN_RATE=0.55
LIVE_REQUIRE_POSITIVE_REHEARSAL_PNL=true

# REDDIT (free — get from reddit.com/prefs/apps, "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=prady-trader/1.0 by u/your_username

# TELEGRAM (optional — create free bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DATABASE (PostgreSQL via Docker, or leave empty for SQLite fallback)
DATABASE_URL=postgresql://trader:password@localhost:5433/prady_trader

# REDIS (via Docker, or leave empty for in-memory fallback)
REDIS_URL=redis://localhost:6379/0

# OLLAMA (free local LLM — falls back to rule-based if unavailable)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_SEC=60

# NVIDIA NIM (optional fallback if Ollama is unavailable)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# SYMBOLS TO TRADE
TRADING_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

# HEDGE GRID PARAMETERS
HEDGE_RATIO=0.4
HARVEST_THRESHOLD=0.003
MAX_HOLD_MINUTES=240
DAILY_PROFIT_TARGET=0.03

# ── Phase 3: Extended API Keys (all free tiers) ──────────────────────

# COINGECKO (optional — free demo key: https://www.coingecko.com/en/api)
COINGECKO_API_KEY=

# NEWSAPI (free 100 req/day: https://newsapi.org/register)
NEWS_API_KEY=

# NEWSDATA.IO (free 200 req/day: https://newsdata.io/register)
NEWSDATA_API_KEY=

# CRYPTOCOMPARE (free 100k calls/mo: https://min-api.cryptocompare.com)
CRYPTOCOMPARE_API_KEY=

# COINAPI (free 100 req/day: https://www.coinapi.io/pricing)
COINAPI_KEY=

# BITQUERY (free 10k points/mo: https://graphql.bitquery.io)
BITQUERY_API_KEY=

# TAAPI.IO (free 1 req/15s: https://taapi.io/register)
TAAPI_SECRET=

# FREECRYPTOAPI (free 100k req/mo: https://freecryptoapi.com/panel)
FREECRYPTO_API_KEY=
