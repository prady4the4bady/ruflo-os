# Control Plane Environment Variables
# Copy to .env and configure

# Server
HOST=127.0.0.1
PORT=9000
WORKERS=2

# Database (PostgreSQL)
DATABASE_URL=postgresql://ruflo:password@localhost/ruflo

# Alternatively, use SQLite for testing:
# DATABASE_URL=sqlite+aiosqlite:///var/lib/ruflo/control-plane.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Model Gateway
MODEL_GATEWAY_URL=http://localhost:8100

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Policy
DEFAULT_POLICY=balanced  # balanced, permissive, strict
