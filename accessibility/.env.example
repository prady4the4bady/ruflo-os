# Accessibility Service Environment Variables
# Copy to .env and configure

# Server
HOST=127.0.0.1
PORT=8200

# Display (for GUI automation)
DISPLAY=:0
WAYLAND_DISPLAY=wayland-0
XDG_RUNTIME_DIR=/run/user/1000

# Control Plane
CONTROL_PLANE_URL=http://localhost:9000

# OCR
TESSERACT_LANG=eng
EASYOCR_GPU=false

# ydotool
YDOTOOL_SOCKET=/tmp/ydotool.socket
