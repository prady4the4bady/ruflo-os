FROM python:3.11-slim AS base

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip

COPY pyproject.toml ./
RUN pip install --no-cache-dir .

COPY src/ ./src/

EXPOSE 8100

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import httpx; httpx.get('http://localhost:8100/healthz').raise_for_status()" || exit 1

CMD ["uvicorn", "ruflo_model_gateway.main:app", "--host", "0.0.0.0", "--port", "8100"]
