# Model Gateway Environment Variables
# Copy to .env and configure

# Server
HOST=127.0.0.1
PORT=8100
WORKERS=2

# Redis
REDIS_URL=redis://localhost:6379/0

# Default provider
DEFAULT_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# NVIDIA NIM (cloud fallback)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Security
API_KEY=  # For authenticating clients
REQURE_AUTH=false  # Set to true in production
